!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel


# typescript
*.tsbuildinfo
next-env.d.ts
local-*
.claude
.z-ai-config
*.log
dev.log
dev.out.log
test
prompt

server.log
# Skills directory
/skills/

# ---- OMEGA: secrets & local data ----
# Database (may contain saved OKX credentials — NEVER commit)
/db/
*.db
*.db-journal

# Upload folder (user conversation logs / private docs)
/upload/

# Tool results & temp files
/tool-results/
/tmp/
/.zscripts/

# Prisma generated client (regenerated on install)
/node_modules/.prisma/

# Build artifacts
/.next/
/mini-services/*/node_modules/

# OS files
Thumbs.db
